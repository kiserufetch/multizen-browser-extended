{
  "name": "@multizen/mcp-server",
  "version": "0.2.11",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "multizen-mcp": "./bin/multizen-mcp.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/standalone.ts",
    "test": "node --import tsx --test src/HttpTransport.test.ts src/cdpTools.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@multizen/profile-manager": "workspace:*",
    "@multizen/types": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
